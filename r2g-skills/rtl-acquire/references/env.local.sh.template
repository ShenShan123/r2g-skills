# Optional local overrides for rtl-acquire.
#
# NORMALLY YOU DO NOT EDIT THIS BY HAND: eda-install's
# `scripts/setup/write_env_local.sh` generates references/env.local.sh with the
# toolchain pins (ORFS_ROOT, tool binaries, R2G_GRAPH_PYTHON) for all r2g
# sub-skills, and scripts/flow/_env.sh autodetects the rest. Copy this file to
# references/env.local.sh only to override the corpus roots or knobs below.

# --- toolchain (usually pinned by eda-install; _env.sh autodetects) ----------
# export ORFS_ROOT=/path/to/OpenROAD-flow-scripts
# export YOSYS_EXE=/path/to/yosys
# export R2G_GRAPH_PYTHON=/path/to/torch-venv/bin/python   # graph stage; SKIPs when unset

# --- corpus roots (default: <repo>/design_cases/_rtl_acquire) ----------------
# export R2G_ACQUIRE_ROOT=/big/volume/rtl_acquire
# export R2G_ACQUIRE_DOWNLOADS=$R2G_ACQUIRE_ROOT/_downloads
# export R2G_ACQUIRE_WORKSPACE=$R2G_ACQUIRE_ROOT/workspace
# export R2G_ACQUIRE_OUT=$R2G_ACQUIRE_ROOT/corpus
# export R2G_ACQUIRE_SEED_ROOT=$R2G_ACQUIRE_ROOT/orfs_seed_designs
# export R2G_ACQUIRE_MERGED_MANIFEST=$R2G_ACQUIRE_ROOT/netlist_graph_corpus_manifest.csv

# --- knobs -------------------------------------------------------------------
# export R2G_ACQUIRE_PLATFORM=nangate45
# export R2G_ACQUIRE_SYNTH_TIMEOUT=3600
# export R2G_ACQUIRE_NUM_CORES=8            # cap per-flow cores (Hard Rule)
# export R2G_ACQUIRE_STATUS_JSON=$R2G_ACQUIRE_ROOT/rtl_acquire_status.json
# export R2G_ACQUIRE_STATUS_LOG=$R2G_ACQUIRE_ROOT/rtl_acquire_status.log
# export R2G_ACQUIRE_CLONE_TIMEOUT_SECONDS=900
# export R2G_ACQUIRE_SV2V_BIN=/path/to/sv2v          # optional converters
# export R2G_ACQUIRE_VHD2VL_BIN=/path/to/vhd2vl
# export R2G_ACQUIRE_ENABLE_LLM=1            # opt-in LLM patch path (default OFF)
