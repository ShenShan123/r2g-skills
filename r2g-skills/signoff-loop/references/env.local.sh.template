# Local environment overrides for the signoff-loop skill.
#
# Copy this file to references/env.local.sh (same directory) and edit in place
# to pin the skill's tool discovery to paths on your machine. Every value is
# optional — anything left commented out falls back to the autodetection in
# scripts/flow/_env.sh (env vars > $PATH > well-known install locations).
#
# Alternatively, point the skill at a file outside the repo via:
#   export R2G_ENV_FILE=/path/to/your-env.sh

# --- OpenROAD-flow-scripts checkout --------------------------------------
# Must contain flow/Makefile. If the skill can't find this, nothing works.
# export ORFS_ROOT="$HOME/OpenROAD-flow-scripts"

# --- Tool binaries -------------------------------------------------------
# Any *_EXE / *_CMD set here takes precedence over $PATH lookup.
# export OPENROAD_EXE=/usr/local/bin/openroad
# export YOSYS_EXE=/usr/local/bin/yosys
# export IVERILOG_EXE=/usr/bin/iverilog
# export VVP_EXE=/usr/bin/vvp
# export VERILATOR_EXE=/usr/local/bin/verilator
# export KLAYOUT_CMD=/usr/bin/klayout
# export MAGIC_EXE=/usr/bin/magic
# export NETGEN_EXE=/usr/bin/netgen-lvs
# export STA_EXE=/usr/local/bin/opensta

# --- PDK roots -----------------------------------------------------------
# Used by run_magic_drc.sh and run_netgen_lvs.sh for sky130A.
# export PDK_ROOT="$HOME/pdks"

# Example: pull everything from a single OSS-CAD-Suite install
# _osscs="$HOME/oss-cad-suite"
# export YOSYS_EXE="$_osscs/bin/yosys"
# export IVERILOG_EXE="$_osscs/bin/iverilog"
# export VVP_EXE="$_osscs/bin/vvp"
# export VERILATOR_EXE="$_osscs/bin/verilator"

# Example: no-sudo signoff toolchain from a Miniconda 'eda' env (litex-hub channel)
# plus the open_pdks sky130A PDK. See README.md "Installing the signoff toolchain
# without sudo". Stage the ~8GB PDK on a volume with space if $HOME is small.
# _eda="$HOME/miniconda3/envs/eda/bin"
# export IVERILOG_EXE="$_eda/iverilog"
# export VVP_EXE="$_eda/vvp"
# export MAGIC_EXE="$_eda/magic"
# export NETGEN_EXE="$_eda/netgen"
# export PDK_ROOT="$HOME/miniconda3/envs/eda/share/pdk"   # or a big-volume copy of sky130A/
