equivalent_pins("AOI22_X2","A1","A2")
equivalent_pins("AOI22_X2","B1","B2")
equivalent_pins("AOI22_X4","A1","A2")
equivalent_pins("AOI22_X4","B1","B2")

equivalent_pins("OAI211_X1","A","B")
equivalent_pins("OAI211_X1","C1","C2")
equivalent_pins("OAI211_X2","A","B")
equivalent_pins("OAI211_X2","C1","C2")
equivalent_pins("OAI211_X4","A","B")
equivalent_pins("OAI211_X4","C1","C2")
equivalent_pins("OAI21_X1","B1","B2")
equivalent_pins("OAI21_X2","B1","B2")
equivalent_pins("OAI21_X4","B1","B2")
equivalent_pins("OAI221_X1","B1","B2")
equivalent_pins("OAI221_X1","C1","C2")
equivalent_pins("OAI221_X2","B1","B2")
equivalent_pins("OAI221_X2","C1","C2")
equivalent_pins("OAI221_X4","B1","B2")
equivalent_pins("OAI221_X4","C1","C2")
equivalent_pins("OAI222_X1","A1","A2")
equivalent_pins("OAI222_X1","B1","B2")
equivalent_pins("OAI222_X1","C1","C2")
equivalent_pins("OAI222_X2","A1","A2")
equivalent_pins("OAI222_X2","B1","B2")
equivalent_pins("OAI222_X2","C1","C2")
equivalent_pins("OAI222_X4","A1","A2")
equivalent_pins("OAI222_X4","B1","B2")
equivalent_pins("OAI222_X4","C1","C2")
equivalent_pins("OAI22_X1","A1","A2")
equivalent_pins("OAI22_X1","B1","B2")
equivalent_pins("OAI22_X2","A1","A2")
equivalent_pins("OAI22_X2","B1","B2")
equivalent_pins("OAI22_X4","A1","A2")
equivalent_pins("OAI22_X4","B1","B2")
equivalent_pins("OAI33_X1","A1","A2","A3")
equivalent_pins("OAI33_X1","B1","B2","B3")

equivalent_pins("HA_X1","A","B")

# Netlist-comparer search budget (env-overridable for operator tuning).
# These bound how far the matcher backtracks to disambiguate symmetric structures.
# EMPIRICAL FINDING (2026-06-02, signoff-fixer campaign): raising these does NOT
# resolve the corpus's LVS "Netlists don't match" residuals.  Tested on
# verilog_ethernet_axis_baser_rx_64 (depth 32) and iccad2017_unit5_F (depth 64,
# complexity 1M): the "Maximum depth exhausted" *warning* disappears but the
# actual net/instance mismatches persist unchanged (2 and 292 respectively).
# Those failures are genuine KLayout-0.30.7 matcher limitations on symmetric logic
# (parallel NAND/NOR trees, register files, flat combinational benchmarks), NOT a
# budget problem and NOT a real layout error -- see references/failure-patterns.md
# "LVS symmetric-matcher residual".  Defaults kept at the validated values; the env
# knobs exist only so an operator can experiment on a future depth-limited design
# without editing the deck.  Raising the budget can never turn a real match into a
# mismatch (only the reverse), so it is always safe to try.
max_branch_complexity((ENV['LVS_MAX_BRANCH_COMPLEXITY'] || 65536).to_i)
max_depth((ENV['LVS_MAX_DEPTH'] || 16).to_i)

# --- VERBOSE-MISMATCH PATCH (wave_f2 diagnosis 2026-05-28) ---
# Force lvsdb to be written even on mismatch by explicitly calling report_lvs
# after compare(). Wrap in begin/rescue to keep going through KLayout exceptions.
# Also dump top-level circuit summary into the log so we can categorize mismatches
# even if lvsdb write fails (e.g. SIGSEGV during gen_log_entry).
# === SYMMETRIC-MATCHER SEEDING (same_nets! on swapped-instance INPUT nets) ===
# Two-pass: $lvs_prior_db is a prior FAILING lvsdb. We read the swapped subcircuit
# instance ids + the matched-net xref from it, then for each swapped LAYOUT instance
# seed same_nets! on its INPUT-pin nets only (output/power pins excluded -- seeding the
# swapped gate's own output net over-constrains and re-fails). Layout net <-> schematic
# net pairing comes from the prior lvsdb xref (deterministic across re-runs).
OUTPUT_PINS = %w(ZN Z Q QN S CO CON SO CO_N COUT Y ZN1 ICO)
if $lvs_prior_db && File.exist?($lvs_prior_db)
  db = File.read($lvs_prior_db)
  ltop = netlist.top_circuit.name
  stop = schematic.top_circuit.name
  # xref region
  xs = db.index(/^ circuit\(#{Regexp.escape(ltop)} #{Regexp.escape(stop)} (?:match|nomatch)/)
  ls = db.index(/^ circuit\(#{Regexp.escape(ltop)}$/)
  ss = db.index(/^ circuit\(#{Regexp.escape(stop)}$/)
  lay = db[ls...ss]; sch = db[ss...xs]; xref = db[xs..-1]
  lay_net = {}; lay.scan(/net\((\d+) name\(([^)]+)\)/) { |i,nm| lay_net[i.to_i]=nm }
  sch_net = {}; sch.scan(/net\((\d+) name\(([^)]+)\)/) { |i,nm| sch_net[i.to_i]=nm }
  xnet = {}; xref.scan(/net\((\d+) (\d+) (?:match|warning)\)/) { |l,s| xnet[l.to_i]=s.to_i }
  swap_lids = xref.scan(/circuit\((\d+) (\d+) mismatch\)/).map { |l,s| l.to_i }
  lc = netlist.circuit_by_name(ltop); sc = schematic.circuit_by_name(stop)
  lay_by_label = {}; lc.each_net { |n| lay_by_label[n.expanded_name] = n }
  applied = 0
  lc.each_subcircuit do |sub|
    next unless swap_lids.include?(sub.id)
    cd = sub.circuit_ref
    cd.each_pin do |p|
      next if OUTPUT_PINS.include?(p.name) || p.name == "VDD" || p.name == "VSS"
      net = sub.net_for_pin(p.id); next unless net
      lname = net.expanded_name
      # find layout net id from prior db by name (lay_net is id->name; invert via scan)
      lid = lay_net.key(lname); next unless lid
      sid = xnet[lid]; next unless sid
      sname = sch_net[sid]; next unless sname
      sn = sc.net_by_name(sname); next unless sn
      begin; same_nets!(ltop, net, stop, sn); applied += 1; rescue => e; end
    end
  end
  $stdout.write "SYMSEED applied #{applied} same_nets! constraints from #{$lvs_prior_db}\n"
end
compare_result = false
begin
  compare_result = compare
rescue => e
  $stdout.write "VERBOSE-LVS: compare raised exception: #{e.class}: #{e.message}\n"
  e.backtrace[0,10].each { |b| $stdout.write "  #{b}\n" } if e.backtrace
end

# Dump per-top-circuit pin/device/net counts so we can at least see structural deltas
# even if lvsdb write later fails.
begin
  ln = netlist
  ls = schematic
  $stdout.write "VERBOSE-LVS: layout top circuits:\n"
  ln.each_circuit_top_down do |c|
    $stdout.write "  L  #{c.name}  pins=#{c.pin_count}  devs=#{c.device_count}  nets=#{c.net_count}  subs=#{c.child_circuit_count}\n"
  end
  $stdout.write "VERBOSE-LVS: schematic top circuits:\n"
  ls.each_circuit_top_down do |c|
    $stdout.write "  S  #{c.name}  pins=#{c.pin_count}  devs=#{c.device_count}  nets=#{c.net_count}  subs=#{c.child_circuit_count}\n"
  end
rescue => e
  $stdout.write "VERBOSE-LVS: circuit dump raised: #{e.class}: #{e.message}\n"
end

# Force-write the LVS database even on mismatch (KLayout normally writes on
# clean compare; explicit call ensures the file exists for both outcomes).
if $report_file
  begin
    report_lvs($report_file, true)
    $stdout.write "VERBOSE-LVS: wrote lvsdb to #{$report_file}\n"
  rescue => e
    $stdout.write "VERBOSE-LVS: report_lvs failed: #{e.class}: #{e.message}\n"
  end
end

if ! compare_result
  puts "ERROR : Netlists don't match"
else
  puts "CONGRATULATIONS! Netlists match."
end

time = Time.now
hours = ((time - tstart)/3600).to_i
minutes = ((time - tstart)/60 - hours * 60).to_i
seconds = ((time - tstart) - (minutes * 60 + hours * 3600)).to_i
$stdout.write "LVS finished at : #{time.hour}:#{time.min}:#{time.sec}  -  LVS duration =  #{hours} hrs. #{minutes} min. #{seconds} sec.\n"